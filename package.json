{
  "name": "@jweiland/video-shariff",
  "private": true,
  "description": "Build tooling for the video_shariff TYPO3 extension's frontend JavaScript.",
  "license": "GPL-2.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/jweiland-net/video_shariff.git"
  },
  "scripts": {
    "build:js": "esbuild Resources/Public/JavaScript/VideoShariff.js --minify --target=es2020 --legal-comments=none --outfile=Resources/Public/JavaScript/VideoShariff.min.js",
    "watch:js": "npm run build:js -- --watch",
    "verify:js": "npm run build:js && git diff --exit-code -- Resources/Public/JavaScript/VideoShariff.min.js"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "engines": {
    "node": ">=20"
  }
}
