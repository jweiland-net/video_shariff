lib.contentElement {
  partialRootPaths {
    1526542481 = EXT:video_shariff/Resources/Private/Extensions/fluid_styled_content/Partials/
    1526542482 = EXT:video_shariff/Resources/Private/Extensions/camino/Partials/
  }
}

plugin.tx_news {
  view {
    partialRootPaths {
      1526542481 = EXT:video_shariff/Resources/Private/Extensions/news/Partials/
    }
  }
}

[{$videoShariff.defaultThumbnail}]
  lib.contentElement.settings.video_shariff.defaultThumbnail = {$videoShariff.defaultThumbnail}
  plugin.tx_news.settings.video_shariff.defaultThumbnail = {$videoShariff.defaultThumbnail}
[else]
  lib.contentElement.settings.video_shariff.defaultThumbnail = 'EXT:video_shariff/Resources/Public/Images/DefaultThumbnail.png'
  plugin.tx_news.settings.video_shariff.defaultThumbnail = 'EXT:video_shariff/Resources/Public/Images/DefaultThumbnail.png'
[END]
